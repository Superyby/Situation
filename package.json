{
  "name": "orbital-tracker",
  "version": "2.0.0",
  "type": "module",
  "description": "React + Three.js (R3F) + GSAP 在轨卫星追踪可视化项目",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "vite --mode development",
    "dev:test": "vite --mode test",
    "build": "tsc -b && vite build --mode production",
    "build:test": "tsc -b && vite build --mode test",
    "preview": "vite preview",
    "start": "vite preview --port 5544",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist node_modules/.vite"
  },
  "dependencies": {
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "gsap": "^3.14.2",
    "satellite.js": "^5.0.0",
    "pnpm": "^10.30.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}