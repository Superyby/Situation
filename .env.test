# ============================================
# 测试环境配置
# ============================================

# 环境标识
VITE_APP_ENV=test

# API 基础地址
VITE_API_BASE_URL=https://test-api.your-domain.com/api

# 后端服务地址
VITE_BACKEND_URL=localhost:8080

# KeepTrack API
VITE_KEEPTRACK_API=https://api.keeptrack.space/v2

# Space-Track API
VITE_SPACETRACK_PROXY=/api/spacetrack

# 调试模式
VITE_DEBUG=true

# 日志级别
VITE_LOG_LEVEL=info

# 卫星加载数量
VITE_SATELLITE_LIMIT=2000
