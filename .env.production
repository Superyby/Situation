# ============================================
# 生产环境配置
# ============================================

# 环境标识
VITE_APP_ENV=production

# API 基础地址（生产环境直接请求后端）
VITE_API_BASE_URL=https://your-backend-domain.com/api

# 后端服务地址
VITE_BACKEND_URL=https://your-backend-domain.com

# KeepTrack API
VITE_KEEPTRACK_API=https://api.keeptrack.space/v2

# Space-Track API（生产环境通过后端代理）
VITE_SPACETRACK_PROXY=/api/spacetrack

# 调试模式
VITE_DEBUG=false

# 日志级别
VITE_LOG_LEVEL=error

# 卫星加载数量
VITE_SATELLITE_LIMIT=5000
